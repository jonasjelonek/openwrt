/dts-v1/;

#include "rtl931x.dtsi"

#include <dt-bindings/input/input.h>
#include <dt-bindings/gpio/gpio.h>

/ {
	compatible = "netgear,ms510txm", "realtek,rtl838x-soc";
	model = "Netgear MS510TXM";

	chosen {
		bootargs = "earlycon ignore_loglevel";
	};

	i2c_bus: i2c-rtl9310@1b0036c {
		compatible = "realtek,rtl9310-i2c";
		reg = <0x1b00036c 0x3c>;
		#address-cells = <1>;
		#size-cells = <0>;
		sda-pin = <15>;
		scl-pin = <13>;
		clock-frequency = <100000>;
	};

	i2c-mux {
		compatible = "realtek,i2c-mux-rtl9310";
		#address-cells = <1>;
		#size-cells = <0>;
		i2c-parent = <&i2c_bus>;

		i2c0: i2c@0 {
			reg = <0>;
			scl-pin = <13>;
			sda-pin = <16>;
		};

		i2c1: i2c@1 {
			reg = <1>;
			scl-pin = <13>;
			sda-pin = <15>;
		};
	};

	sfp0: sfp-p1 {
		compatible = "sff,sfp";
		i2c-bus = <&i2c0>;
		los-gpio = <&gpio0 9 GPIO_ACTIVE_HIGH>;
		tx-disable-gpio = <&gpio0 11 GPIO_ACTIVE_HIGH>;
	};

	sfp1: sfp-p2 {
		compatible = "sff,sfp";
		i2c-bus = <&i2c1>;
		los-gpio = <&gpio0 8 GPIO_ACTIVE_HIGH>;
		tx-disable-gpio = <&gpio0 10 GPIO_ACTIVE_HIGH>;
	};
};

&spi0 {
	status = "okay";

	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			partition@0 {
				label = "u-boot";
				reg = <0x0 0xe0000>;
				read-only;
			};
			partition@1 {
				label = "u-boot-env";
				reg = <0xe0000 0x10000>;
			};
			partition@2 {
				label = "u-boot-env2";
				reg = <0xf0000 0x10000>;
				read-only;
			};
			partition@3 {
				label = "jffs2-cfg";
				reg = <0x100000 0x100000>;
			};
			partition@4 {
				label = "jffs2-log";
				reg = <0x200000 0x100000>;
			};
			partition@5 {
				label = "firmware";
				reg = <0x300000 0xe80000>;
			};
			partition@6 {
				label = "firmware2";
				reg = <0x1180000 0xe80000>;
			};
		};
	};
};

&ethernet0 {
	mdio: mdio-bus {
		compatible = "realtek,rtl838x-mdio";
		regmap = <&ethernet0>;
		#address-cells = <1>;
		#size-cells = <0>;

		/* External RTL8221B */
		phy0: ethernet-phy@0 {
			reg = <0>;
			compatible = "ethernet-phy-ieee802.3-c45";
			rtl9300,smi-address = <0 0>;
			sds = <0>;
		};
		phy8: ethernet-phy@8 {
			reg = <8>;
			compatible = "ethernet-phy-ieee802.3-c45";
			rtl9300,smi-address = <0 1>;
			sds = <1>;
		};
		phy16: ethernet-phy@10 {
			reg = <16>;
			compatible = "ethernet-phy-ieee802.3-c45";
			rtl9300,smi-address = <0 2>;
			sds = <2>;
		};
		phy24: ethernet-phy@18 {
			reg = <24>;
			compatible = "ethernet-phy-ieee802.3-c45";
			rtl9300,smi-address = <1 3>;
			sds = <3>;
		};

		/* External BCM84888 */
		phy32: ethernet-phy@20 {
			reg = <32>;
			compatible = "ethernet-phy-ieee802.3-c45";
			rtl9300,smi-address = <3 4>;
			sds = <4>;
		};
		phy40: ethernet-phy@28 {
			reg = <40>;
			compatible = "ethernet-phy-ieee802.3-c45";
			rtl9300,smi-address = <3 5>;
			sds = <5>;
		};
		phy48: ethernet-phy@30 {
			reg = <48>;
			compatible = "ethernet-phy-ieee802.3-c45";
			rtl9300,smi-address = <3 6>;
			sds = <6>;
		};
		phy50: ethernet-phy@32 {
			reg = <50>;
			compatible = "ethernet-phy-ieee802.3-c45";
			rtl9300,smi-address = <3 7>;
			sds = <7>;
		};
		
		/* SFPs */
		phy54: ethernet-phy@36 {
			reg = <54>;
			compatible = "ethernet-phy-ieee802.3-c22";
			phy-is-integrated;
			sds = <8>;
		};
		phy55: ethernet-phy@37 {
			reg = <55>;
			compatible = "ethernet-phy-ieee802.3-c22";
			phy-is-integrated;
			sds = <9>;
		};
	};
};

&switch0 {
	ports {
		#address-cells = <1>;
		#size-cells = <0>;

		port@0 {
			reg = <0>;
			label = "lan1";
			phy-handle = <&phy0>;
			phy-mode = "hsgmii";
		};
		port@8 {
		        reg = <8>;
        		label = "lan2";
        		phy-handle = <&phy8>;
        		phy-mode = "hsgmii";
		};
		port@10 {
			reg = <16>;
			label = "lan3";
			phy-handle = <&phy16>;
			phy-mode = "hsgmii";
		};
		port@18 {
			reg = <24>;
			label = "lan4";
			phy-handle = <&phy24>;
			phy-mode = "hsgmii";
		};

		/* 10GBase-T ports */
		port@20 {
			reg = <32>;
			label = "lan5";
			phy-handle = <&phy32>;
			phy-mode = "usxgmii";
		};
		port@28 {
			reg = <40>;
			label = "lan6";
			phy-handle = <&phy40>;
			phy-mode = "usxgmii";
		};
		port@30 {
			reg = <48>;
			label = "lan7";
			phy-handle = <&phy48>;
			phy-mode = "usxgmii";
		};
		port@32 {
			reg = <50>;
			label = "lan8";
			phy-handle = <&phy50>;
			phy-mode = "usxgmii";
		};

		/* SFP ports */
		port@36 {
			reg = <54>;
			label = "lan9";
			pseudo-phy-handle = <&phy54>;
			phy-mode = "10gbase-r";
			sfp = <&sfp0>;
			managed = "in-band-status";
		};
		port@37 {
			reg = <55>;
			label = "lan10";
			pseudo-phy-handle = <&phy55>;
			phy-mode = "10gbase-r";
			sfp = <&sfp1>;
			managed = "in-band-status";
		};

		/* CPU port */
		port@38 {
			ethernet = <&ethernet0>;
			reg = <56>;
			phy-mode = "internal";
			fixed-link {
				speed = <10000>;
				full-duplex;
			};
		};
	};
};
