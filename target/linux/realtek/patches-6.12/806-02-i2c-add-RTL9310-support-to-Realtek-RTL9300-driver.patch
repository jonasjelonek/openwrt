-#define RTL9300_I2C_MUX_NCHAN	8
+struct rtl93xx_i2c_drv_data {
+	int (*config_io)(struct rtl93xx_i2c *i2c, u8 sda_pin);
+	int (*config_xfer)(struct rtl93xx_i2c *i2c,
+			   struct rtl93xx_i2c_chan *chan, u16 addr,
+			   u16 len);
+	int (*execute_xfer)(struct rtl93xx_i2c *i2c, char read_write,
+			    int size, union i2c_smbus_data *data, int len);
+	int (*read)(struct rtl93xx_i2c *i2c, u8 *buf, int len);
+	int (*reg_addr_set)(struct rtl93xx_i2c *i2c, u32 reg, u16 len);
+	int (*write)(struct rtl93xx_i2c *i2c, u8 *buf, int len);
+	int (*writel)(struct rtl93xx_i2c *i2c, u32 data);
+	u8 max_nchan;
+};
+
+#define RTL9300_I2C_MUX_NCHAN   8
+#define RTL9310_I2C_MUX_NCHAN	12
 
-struct rtl9300_i2c {
+struct rtl93xx_i2c {
 	struct regmap *regmap;
 	struct device *dev;
-	struct rtl9300_i2c_chan chans[RTL9300_I2C_MUX_NCHAN];
+	struct rtl93xx_i2c_chan chans[RTL9310_I2C_MUX_NCHAN];
 	u32 reg_base;
 	u8 sda_pin;
+	u8 mst_id;
 	struct mutex lock;
 };
 
+
 #define RTL9300_I2C_MST_CTRL1				0x0
 #define  RTL9300_I2C_MST_CTRL1_MEM_ADDR_OFS		8
 #define  RTL9300_I2C_MST_CTRL1_MEM_ADDR_MASK		GENMASK(31, 8)
@@ -60,7 +77,38 @@ struct rtl9300_i2c {
 
 #define RTL9300_I2C_MST_GLB_CTRL			0x384
 
-static int rtl9300_i2c_reg_addr_set(struct rtl9300_i2c *i2c, u32 reg, u16 len)
+
+#define RTL9310_I2C_MST_IF_CTRL				0x1004
+#define RTL9310_I2C_MST_IF_SEL				0x1008
+/* SCL0 is GPIO13, SCL1 is GPIO14 */
+#define  RTL9310_I2C_MST_IF_SEL_GPIO_SCL1_SEL		BIT(13)
+#define  RTL9310_I2C_MST_IF_SEL_GPIO_SCL0_SEL		BIT(12)
+#define  RTL9310_I2C_MST_IF_SEL_GPIO_SDA_SEL_OFS	0
+#define  RTL9310_I2C_MST_IF_SEL_GPIO_SDA_SEL_MASK	GENMASK(11, 0)
+
+#define RTL9310_I2C_MST_CTRL				0x0
+#define  RTL9310_I2C_MST_CTRL_SCL_FREQ_OFS		30
+#define  RTL9310_I2C_MST_CTRL_SCL_FREQ_MASK		GENMASK(31, 30)
+#define  RTL9310_I2C_MST_CTRL_SDA_OUT_SEL_OFS		18
+#define  RTL9310_I2C_MST_CTRL_SDA_OUT_SEL_MASK		GENMASK(21, 18)
+#define  RTL9310_I2C_MST_CTRL_DEV_ADDR_OFS		11
+#define  RTL9310_I2C_MST_CTRL_DEV_ADDR_MASK		GENMASK(17, 11)
+#define  RTL9310_I2C_MST_CTRL_MEMADDR_WIDTH_OFS		9
+#define  RTL9310_I2C_MST_CTRL_MEMADDR_WIDTH_MASK	GENMASK(10, 9)
+#define  RTL9310_I2C_MST_CTRL_DATA_WIDTH_OFS		5
+#define  RTL9310_I2C_MST_CTRL_DATA_WIDTH_MASK		GENMASK(8, 5)
+#define  RTL9310_I2C_MST_CTRL_RD_MODE			BIT(4)
+#define  RTL9310_I2C_MST_CTRL_RWOP			BIT(2)
+#define  RTL9310_I2C_MST_CTRL_FAIL			BIT(1)
+#define  RTL9310_I2C_MST_CTRL_TRIG			BIT(0)
+#define RTL9310_I2C_MST_MEMADDR_CTRL			0x4
+#define  RTL9310_I2C_MST_MEMADDR_OFS			0x0
+#define  RTL9310_I2C_MST_MEMADDR_MASK			GENMASK(23, 0)
+#define	RTL9310_I2C_MST_DATA_CTRL			0x8
+
+#define MST_REG(i2c, x)					((i2c)->reg_base + (x))
+
+static int rtl9300_i2c_reg_addr_set(struct rtl93xx_i2c *i2c, u32 reg, u16 len)
 {
 	u32 val, mask;
 	int ret;
@@ -68,17 +116,35 @@ static int rtl9300_i2c_reg_addr_set(struct rtl9300_i2c *i2c, u32 reg, u16 len)
