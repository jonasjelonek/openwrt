From f471718472cc884020cd5b97a8777eb4e8e5cf69 Mon Sep 17 00:00:00 2001
From: Jonas Jelonek <jelonek.jonas@gmail.com>
Date: Thu, 26 Jun 2025 11:32:57 +0000
Subject: [PATCH 2/2] i2c: add RTL9310 support to Realtek RTL9300 driver

This adds support for Realtek RTL9310 series to the I2C driver for the
RTL9300 I2C controller.

The I2C controller in RTL9310 SoCs differs from the one in RTL9300 by a
slightly different register layout, that it supports 12 instead of 8
channels/SDA lines and it uses GPIO13 and GPIO14 as SCL lines.

A new property 'realtek,mst-id' is added to the device-tree binding to
tell the driver which master is used. This is required because
activating the SCL line is done in a global register - contrast to a
local register in RTL9300.

This also slightly adjusts the RTL9300 part of the driver for
improvements, and in general does some renaming to reflect that it's not
just for RTL9300.

Signed-off-by: Jonas Jelonek <jelonek.jonas@gmail.com>

diff --git a/drivers/i2c/busses/i2c-rtl9300.c b/drivers/i2c/busses/i2c-rtl9300.c
index e02a8ba40f6f..c87ee1c3d7e8 100644
--- a/drivers/i2c/busses/i2c-rtl9300.c
+++ b/drivers/i2c/busses/i2c-rtl9300.c
@@ -9,31 +9,48 @@
 #include <linux/platform_device.h>
 #include <linux/regmap.h>
 
-enum rtl9300_bus_freq {
-	RTL9300_I2C_STD_FREQ,
-	RTL9300_I2C_FAST_FREQ,
+enum rtl93xx_bus_freq {
+	RTL93XX_I2C_STD_FREQ,
+	RTL93XX_I2C_FAST_FREQ,
 };
 
-struct rtl9300_i2c;
+struct rtl93xx_i2c;
 
-struct rtl9300_i2c_chan {
+struct rtl93xx_i2c_chan {
 	struct i2c_adapter adap;
-	struct rtl9300_i2c *i2c;
-	enum rtl9300_bus_freq bus_freq;
+	struct rtl93xx_i2c *i2c;
+	enum rtl93xx_bus_freq bus_freq;
 	u8 sda_pin;
