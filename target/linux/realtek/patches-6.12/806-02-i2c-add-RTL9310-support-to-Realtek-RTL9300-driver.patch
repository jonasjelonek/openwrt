 	mask = RTL9300_I2C_MST_CTRL2_MEM_ADDR_WIDTH_MASK;
 
-	ret = regmap_update_bits(i2c->regmap, i2c->reg_base + RTL9300_I2C_MST_CTRL2, mask, val);
+	ret = regmap_update_bits(i2c->regmap, MST_REG(i2c, RTL9300_I2C_MST_CTRL2), mask, val);
 	if (ret)
 		return ret;
 
 	val = reg << RTL9300_I2C_MST_CTRL1_MEM_ADDR_OFS;
 	mask = RTL9300_I2C_MST_CTRL1_MEM_ADDR_MASK;
 
-	return regmap_update_bits(i2c->regmap, i2c->reg_base + RTL9300_I2C_MST_CTRL1, mask, val);
+	return regmap_update_bits(i2c->regmap, MST_REG(i2c, RTL9300_I2C_MST_CTRL1), mask, val);
 }
 
-static int rtl9300_i2c_config_io(struct rtl9300_i2c *i2c, u8 sda_pin)
+static int rtl9310_i2c_reg_addr_set(struct rtl93xx_i2c *i2c, u32 reg, u16 len)
+{
+	u32 val, mask;
+	int ret;
+
+	val = len << RTL9310_I2C_MST_CTRL_MEMADDR_WIDTH_OFS;
+	mask = RTL9310_I2C_MST_CTRL_MEMADDR_WIDTH_MASK;
+
+	ret = regmap_update_bits(i2c->regmap, MST_REG(i2c, RTL9310_I2C_MST_CTRL), mask, val);
+	if (ret)
+		return ret;
+
+	val = reg << RTL9310_I2C_MST_MEMADDR_OFS;
+	mask = RTL9310_I2C_MST_MEMADDR_MASK;
+
+	return regmap_update_bits(i2c->regmap, MST_REG(i2c, RTL9310_I2C_MST_MEMADDR_CTRL), mask, val);
+}
+
+static int rtl9300_i2c_config_io(struct rtl93xx_i2c *i2c, u8 sda_pin)
 {
 	int ret;
 	u32 val, mask;
@@ -91,10 +157,30 @@ static int rtl9300_i2c_config_io(struct rtl9300_i2c *i2c, u8 sda_pin)
 		RTL9300_I2C_MST_CTRL1_GPIO_SCL_SEL;
 	mask = RTL9300_I2C_MST_CTRL1_SDA_OUT_SEL_MASK | RTL9300_I2C_MST_CTRL1_GPIO_SCL_SEL;
 
-	return regmap_update_bits(i2c->regmap, i2c->reg_base + RTL9300_I2C_MST_CTRL1, mask, val);
+	return regmap_update_bits(i2c->regmap, MST_REG(i2c, RTL9300_I2C_MST_CTRL1), mask, val);
+}
+
+static int rtl9310_i2c_config_io(struct rtl93xx_i2c *i2c, u8 sda_pin)
+{
+	u32 val, mask;
+	int ret;
+
+	if (i2c->mst_id == 2)
+		val = mask = BIT(sda_pin) | RTL9310_I2C_MST_IF_SEL_GPIO_SCL1_SEL;
+	else
+		val = mask = BIT(sda_pin) | RTL9310_I2C_MST_IF_SEL_GPIO_SCL0_SEL;
+
+	ret = regmap_update_bits(i2c->regmap, RTL9310_I2C_MST_IF_SEL, mask, val);
+	if (ret)
+		return ret;
+
+	val = (sda_pin << RTL9310_I2C_MST_CTRL_SDA_OUT_SEL_OFS);
+	mask = RTL9310_I2C_MST_CTRL_SDA_OUT_SEL_MASK;
+
+	return regmap_update_bits(i2c->regmap, MST_REG(i2c, RTL9310_I2C_MST_CTRL), mask, val);
 }
 
-static int rtl9300_i2c_config_xfer(struct rtl9300_i2c *i2c, struct rtl9300_i2c_chan *chan,
+static int rtl9300_i2c_config_xfer(struct rtl93xx_i2c *i2c, struct rtl93xx_i2c_chan *chan,
 				   u16 addr, u16 len)
 {
 	u32 val, mask;
@@ -110,10 +196,29 @@ static int rtl9300_i2c_config_xfer(struct rtl9300_i2c *i2c, struct rtl9300_i2c_c
 
 	mask |= RTL9300_I2C_MST_CTRL2_RD_MODE;
 
-	return regmap_update_bits(i2c->regmap, i2c->reg_base + RTL9300_I2C_MST_CTRL2, mask, val);
+	return regmap_update_bits(i2c->regmap, MST_REG(i2c, RTL9300_I2C_MST_CTRL2), mask, val);
 }
 
-static int rtl9300_i2c_read(struct rtl9300_i2c *i2c, u8 *buf, int len)
+static int rtl9310_i2c_config_xfer(struct rtl93xx_i2c *i2c, struct rtl93xx_i2c_chan *chan,
+				   u16 addr, u16 len)
+{
+	u32 val, mask;
+
+	val = chan->bus_freq << RTL9310_I2C_MST_CTRL_SCL_FREQ_OFS;
+	mask = RTL9310_I2C_MST_CTRL_SCL_FREQ_MASK;
+
+	val |= addr << RTL9310_I2C_MST_CTRL_DEV_ADDR_OFS;
+	mask |= RTL9310_I2C_MST_CTRL_DEV_ADDR_MASK;
+
+	val |= ((len - 1) & 0xf) << RTL9310_I2C_MST_CTRL_DATA_WIDTH_OFS;
+	mask |= RTL9310_I2C_MST_CTRL_DATA_WIDTH_MASK;
+
+	mask |= RTL9310_I2C_MST_CTRL_RD_MODE;
+
+	return regmap_update_bits(i2c->regmap, MST_REG(i2c, RTL9310_I2C_MST_CTRL), mask, val);
+}
+
+static int i2c_read(struct rtl93xx_i2c *i2c, u8 reg, u8 *buf, int len)
 {
 	u32 vals[4] = {};
 	int i, ret;
@@ -121,8 +226,7 @@ static int rtl9300_i2c_read(struct rtl9300_i2c *i2c, u8 *buf, int len)
 	if (len > 16)
 		return -EIO;
 
-	ret = regmap_bulk_read(i2c->regmap, i2c->reg_base + RTL9300_I2C_MST_DATA_WORD0,
-			       vals, ARRAY_SIZE(vals));
+	ret = regmap_bulk_read(i2c->regmap, reg, vals, ARRAY_SIZE(vals));
 	if (ret)
 		return ret;
 
@@ -134,7 +238,17 @@ static int rtl9300_i2c_read(struct rtl9300_i2c *i2c, u8 *buf, int len)
 	return 0;
 }
 
-static int rtl9300_i2c_write(struct rtl9300_i2c *i2c, u8 *buf, int len)
+static int rtl9300_i2c_read(struct rtl93xx_i2c *i2c, u8 *buf, int len)
+{
+	return i2c_read(i2c, MST_REG(i2c, RTL9300_I2C_MST_DATA_WORD0), buf, len);
+}
+
+static int rtl9310_i2c_read(struct rtl93xx_i2c *i2c, u8 *buf, int len)
+{
+	return i2c_read(i2c, MST_REG(i2c, RTL9310_I2C_MST_DATA_CTRL), buf, len);
+}
+
+static int i2c_write(struct rtl93xx_i2c *i2c, u8 reg, u8 *buf, int len)
 {
 	u32 vals[4] = {};
 	int i;
@@ -149,16 +263,30 @@ static int rtl9300_i2c_write(struct rtl9300_i2c *i2c, u8 *buf, int len)
 		vals[i/4] |= buf[i];
 	}
 
-	return regmap_bulk_write(i2c->regmap, i2c->reg_base + RTL9300_I2C_MST_DATA_WORD0,
-				vals, ARRAY_SIZE(vals));
+	return regmap_bulk_write(i2c->regmap, reg, vals, ARRAY_SIZE(vals));
 }
 
-static int rtl9300_i2c_writel(struct rtl9300_i2c *i2c, u32 data)
+static int rtl9300_i2c_write(struct rtl93xx_i2c *i2c, u8 *buf, int len)
 {
-	return regmap_write(i2c->regmap, i2c->reg_base + RTL9300_I2C_MST_DATA_WORD0, data);
+	return i2c_write(i2c, MST_REG(i2c, RTL9300_I2C_MST_DATA_WORD0), buf, len);
 }
 
-static int rtl9300_i2c_execute_xfer(struct rtl9300_i2c *i2c, char read_write,
+static int rtl9310_i2c_write(struct rtl93xx_i2c *i2c, u8 *buf, int len)
+{
+	return i2c_write(i2c, MST_REG(i2c, RTL9310_I2C_MST_DATA_CTRL), buf, len);
+}
+
+static int rtl9300_i2c_writel(struct rtl93xx_i2c *i2c, u32 data)
+{
+	return regmap_write(i2c->regmap, MST_REG(i2c, RTL9300_I2C_MST_DATA_WORD0), data);
+}
+
+static int rtl9310_i2c_writel(struct rtl93xx_i2c *i2c, u32 data)
+{
+	return regmap_write(i2c->regmap, MST_REG(i2c, RTL9310_I2C_MST_DATA_CTRL), data);
+}
+
+static int rtl9300_i2c_execute_xfer(struct rtl93xx_i2c *i2c, char read_write,
 				    int size, union i2c_smbus_data *data, int len)
 {
 	u32 val, mask;
@@ -170,11 +298,11 @@ static int rtl9300_i2c_execute_xfer(struct rtl9300_i2c *i2c, char read_write,
 	val |= RTL9300_I2C_MST_CTRL1_I2C_TRIG;
 	mask |= RTL9300_I2C_MST_CTRL1_I2C_TRIG;
 
-	ret = regmap_update_bits(i2c->regmap, i2c->reg_base + RTL9300_I2C_MST_CTRL1, mask, val);
+	ret = regmap_update_bits(i2c->regmap, MST_REG(i2c, RTL9300_I2C_MST_CTRL1), mask, val);
 	if (ret)
 		return ret;
 
-	ret = regmap_read_poll_timeout(i2c->regmap, i2c->reg_base + RTL9300_I2C_MST_CTRL1,
+	ret = regmap_read_poll_timeout(i2c->regmap, MST_REG(i2c, RTL9300_I2C_MST_CTRL1),
 				       val, !(val & RTL9300_I2C_MST_CTRL1_I2C_TRIG), 100, 2000);
 	if (ret)
 		return ret;
@@ -185,13 +313,13 @@ static int rtl9300_i2c_execute_xfer(struct rtl9300_i2c *i2c, char read_write,
 	if (read_write == I2C_SMBUS_READ) {
 		if (size == I2C_SMBUS_BYTE || size == I2C_SMBUS_BYTE_DATA) {
 			ret = regmap_read(i2c->regmap,
-					  i2c->reg_base + RTL9300_I2C_MST_DATA_WORD0, &val);
+					  MST_REG(i2c, RTL9300_I2C_MST_DATA_WORD0), &val);
 			if (ret)
 				return ret;
 			data->byte = val & 0xff;
 		} else if (size == I2C_SMBUS_WORD_DATA) {
 			ret = regmap_read(i2c->regmap,
-					  i2c->reg_base + RTL9300_I2C_MST_DATA_WORD0, &val);
+					  MST_REG(i2c, RTL9300_I2C_MST_DATA_WORD0), &val);
 			if (ret)
 				return ret;
 			data->word = val & 0xffff;
@@ -205,17 +333,67 @@ static int rtl9300_i2c_execute_xfer(struct rtl9300_i2c *i2c, char read_write,
 	return 0;
 }
 
-static int rtl9300_i2c_smbus_xfer(struct i2c_adapter *adap, u16 addr, unsigned short flags,
+static int rtl9310_i2c_execute_xfer(struct rtl93xx_i2c *i2c, char read_write,
+				    int size, union i2c_smbus_data *data, int len)
+{
+	u32 val, mask;
+	int ret;
+
+	val = read_write == I2C_SMBUS_WRITE ? RTL9310_I2C_MST_CTRL_RWOP : 0;
+	mask = RTL9310_I2C_MST_CTRL_RWOP;
+
+	val |= RTL9310_I2C_MST_CTRL_TRIG;
+	mask |= RTL9310_I2C_MST_CTRL_TRIG;
+
+	ret = regmap_update_bits(i2c->regmap, MST_REG(i2c, RTL9310_I2C_MST_CTRL), mask, val);
+	if (ret)
+		return ret;
+
+	ret = regmap_read_poll_timeout(i2c->regmap, MST_REG(i2c, RTL9310_I2C_MST_CTRL), val,
+				       !(val & RTL9310_I2C_MST_CTRL_TRIG), 100, 2000);
+	if (ret)
+		return ret;
+
+	if (val & RTL9310_I2C_MST_CTRL_FAIL)
+		return -EIO;
+
+	if (read_write == I2C_SMBUS_READ) {
+		if (size == I2C_SMBUS_BYTE || size == I2C_SMBUS_BYTE_DATA) {
+			ret = regmap_read(i2c->regmap, MST_REG(i2c, RTL9310_I2C_MST_DATA_CTRL),
+					  &val);
+			if (ret)
+				return ret;
+
+			data->byte = val & 0xff;
+		} else if (size == I2C_SMBUS_WORD_DATA) {
+			ret = regmap_read(i2c->regmap, MST_REG(i2c, RTL9310_I2C_MST_DATA_CTRL),
+					  &val);
+			if (ret)
+				return ret;
+
+			data->word = val & 0xffff;
+		} else {
+			ret = rtl9310_i2c_read(i2c, &data->block[0], len);
+			if (ret)
+				return ret;
+		}
+	}
+
+	return 0;
+}
