-			ret = rtl9300_i2c_config_xfer(i2c, chan, addr, 0);
+			ret = drv_data->config_xfer(i2c, chan, addr, 0);
 			if (ret)
 				goto out_unlock;
-			ret = rtl9300_i2c_reg_addr_set(i2c, command, 1);
+			ret = drv_data->reg_addr_set(i2c, command, 1);
 			if (ret)
 				goto out_unlock;
 		} else {
-			ret = rtl9300_i2c_config_xfer(i2c, chan, addr, 1);
+			ret = drv_data->config_xfer(i2c, chan, addr, 1);
 			if (ret)
 				goto out_unlock;
-			ret = rtl9300_i2c_reg_addr_set(i2c, 0, 0);
+			ret = drv_data->reg_addr_set(i2c, 0, 0);
 			if (ret)
 				goto out_unlock;
 		}
 		break;
 
